APP_NAME=InstaRetriv AI
APP_ENV=development
HOST=127.0.0.1
PORT=8000

# Comma-separated list of approved WhatsApp sender numbers.
# Example: whatsapp:+911234567890
AUTHORIZED_SENDERS=

# Local storage paths for MVP
UPLOAD_DIR=uploads

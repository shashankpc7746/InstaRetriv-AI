APP_NAME=InstaRetriv AI
APP_ENV=development
HOST=127.0.0.1
PORT=8000

# Comma-separated list of approved WhatsApp sender numbers.
# Example: whatsapp:+911234567890
AUTHORIZED_SENDERS=

# Local storage paths for MVP
UPLOAD_DIR=uploads
METADATA_FILE=data/metadata.json
REQUEST_LOG_FILE=data/request_logs.json
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,webp,doc,docx

# Public URL used by Twilio to fetch files, example: https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# Twilio credentials (for later media sending phase)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
